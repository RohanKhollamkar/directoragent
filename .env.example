# DirectorAgent settings — copy to .env and fill in.
# These mirror the fields on directoragent.config.Settings.

# Vision phase: openai | anthropic | gemini | mock
VISION_PROVIDER=anthropic
# Blank = provider default model
VISION_MODEL=

# Higgsfield client — REST transport (deployable path, STEP 12.5).
# Auth is `Authorization: Key KEY_ID:KEY_SECRET` against HIGGSFIELD_BASE_URL.
# Set both KEY_ID and KEY_SECRET to run real mode from the CLI / a container.
HIGGSFIELD_KEY_ID=
HIGGSFIELD_KEY_SECRET=
HIGGSFIELD_BASE_URL=https://platform.higgsfield.ai
# Legacy/dead — nothing authenticates with it: agent mode auths via the OAuth
# connector, REST mode via KEY_ID:KEY_SECRET. Kept only because config/pipeline
# still thread it through; removal is a separate cleanup.
HIGGSFIELD_API_KEY=

# Run mode / safety rails
MOCK_MODE=false
MAX_COST_USD=10.0

# State store (SQLite); directory is gitignored
STATE_DB_PATH=.directoragent/state.db

# Logging
LOG_LEVEL=INFO

# --- Web / deploy (STEP D3) ---
# The FastAPI surface (directoragent.web) reads the same settings above.
# PORT is provided by the platform (Render injects it); the start command
# binds it: `uvicorn directoragent.web:app --host 0.0.0.0 --port $PORT`.
# Deploy default is MOCK MODE (free, instant): the web layer runs mock
# whenever HIGGSFIELD_KEY_ID/SECRET are unset (or MOCK_MODE=true). Real REST
# mode needs MOCK_MODE=false + HIGGSFIELD_KEY_ID + HIGGSFIELD_KEY_SECRET
# + a vision provider key.

# --- Read directly by the provider SDKs, not by Settings ---
# Set whichever provider you use for the vision phase.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=
